{% extends 'auth.base' %}

{% block title %}绑定正版账号{% endblock %}

{% block content %}
  {% if success %}
  <div class="alert alert-success">{{ success }}</div>
  {% endif %}

  {% if error %}
  <div class="alert alert-danger">{{ error }}</div>
  {% endif %}

  {% if binding %}
    <p class="login-box-msg">已绑定正版账号</p>
    <p class="text-center"><code>{{ binding.mojang_uuid }}</code></p>
    <p class="text-muted text-center" style="font-size:0.85em;">
      绑定后可用正版启动器直接进入服务器，与皮肤站账号是同一角色。
    </p>
    <form method="POST" action="{{ url('yggdrasil/mojang/unbind') }}">
      {{ csrf_field() }}
      <button type="submit" class="btn btn-danger btn-block mt-2"
        onclick="return confirm('确认解除正版账号绑定？')">解除绑定</button>
    </form>

  {% elseif pending %}
    <p class="login-box-msg">等待验证中</p>
    <div class="alert alert-info" style="font-size:0.9em;">
      已申请绑定正版用户名 <strong>{{ pending.mojang_name }}</strong>，
      请在 15 分钟内用正版启动器加入服务器，检测到后自动完成绑定。
    </div>
    <form method="POST" action="{{ url('yggdrasil/mojang/cancel-bind') }}">
      {{ csrf_field() }}
      <button type="submit" class="btn btn-secondary btn-block">取消申请</button>
    </form>

  {% else %}
    <p class="login-box-msg">绑定 Minecraft 正版账号</p>
    <p style="font-size:0.9em;">
      绑定后可用正版启动器直接进入服务器，皮肤与披风自动同步。
    </p>
    <ol style="font-size:0.9em; padding-left:1.2em;">
      <li>输入您的 Minecraft 正版用户名</li>
      <li>点击提交</li>
      <li>在 15 分钟内用正版启动器加入服务器</li>
    </ol>
    <form method="POST" action="{{ url('yggdrasil/mojang/bind') }}">
      {{ csrf_field() }}
      <div class="input-group mb-3">
        <input type="text" name="mojang_name" class="form-control"
          placeholder="Minecraft 用户名（如 Steve）"
          maxlength="16" required>
      </div>
      <button type="submit" class="btn btn-primary btn-block">提交并等待验证</button>
    </form>
  {% endif %}
{% endblock %}
