{% extends 'user.base' %}

{% block title %}绑定正版账号{% endblock %}

{% block content %}
<div class="container-fluid">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      {% if success %}
      <div class="alert alert-success alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        {{ success }}
      </div>
      {% endif %}

      {% if error %}
      <div class="alert alert-danger alert-dismissible">
        <button type="button" class="close" data-dismiss="alert">&times;</button>
        {{ error }}
      </div>
      {% endif %}

      {% if binding %}

        <div class="card card-success">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-link mr-2"></i>已绑定正版账号</h3>
          </div>
          <div class="card-body">
            <div class="form-group mb-2">
              <label class="text-muted small">Mojang UUID</label>
              <input type="text" class="form-control form-control-sm"
                value="{{ binding.mojang_uuid }}" readonly>
            </div>
            <p class="text-muted small mb-0">
              绑定后可用正版启动器直接加入服务器，与皮肤站账号共享同一角色数据。
            </p>
          </div>
          <div class="card-footer">
            <form method="POST" action="{{ url('yggdrasil/mojang/unbind') }}">
              {{ csrf_field() }}
              <button type="submit" class="btn btn-outline-danger btn-block"
                onclick="return confirm('确认解除正版账号绑定？解除后需重新验证才能用正版启动器加入服务器。')">
                <i class="fas fa-unlink mr-1"></i>解除绑定
              </button>
            </form>
          </div>
        </div>

      {% elseif pending %}

        <div class="card card-warning">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-clock mr-2"></i>等待验证中</h3>
          </div>
          <div class="card-body">
            <div class="callout callout-info mb-3">
              已提交绑定申请，正版用户名：<strong>{{ pending.mojang_name }}</strong>
            </div>
            <p class="mb-1 font-weight-bold">接下来：</p>
            <ol class="pl-3 mb-0">
              <li>打开正版 Minecraft 启动器（不需要安装外置登录）</li>
              <li>加入本服务器</li>
              <li>检测到后自动完成绑定</li>
            </ol>
            <p class="text-muted small mt-2 mb-0">申请在 15 分钟内有效。</p>
          </div>
          <div class="card-footer">
            <form method="POST" action="{{ url('yggdrasil/mojang/cancel-bind') }}">
              {{ csrf_field() }}
              <button type="submit" class="btn btn-secondary btn-block">
                <i class="fas fa-times mr-1"></i>取消申请
              </button>
            </form>
          </div>
        </div>

      {% else %}

        {% if not hasPlayer %}
        <div class="callout callout-warning">
          <h5><i class="fas fa-exclamation-triangle mr-1"></i>需要先创建角色</h5>
          <p class="mb-0">
            绑定前请先在<a href="{{ url('user/player') }}">角色管理</a>页面创建一个角色。
            没有角色时即使通过验证也无法完成绑定。
          </p>
        </div>
        {% endif %}

        <div class="card {% if not hasPlayer %}card-secondary{% else %}card-primary{% endif %}">
          <div class="card-header">
            <h3 class="card-title"><i class="fas fa-gamepad mr-2"></i>绑定 Minecraft 正版账号</h3>
          </div>
          <div class="card-body">
            <div class="callout callout-info">
              绑定后，可直接用官方启动器加入服务器，与皮肤站账号共享角色数据（背包、进度等）。
            </div>
            <form method="POST" action="{{ url('yggdrasil/mojang/bind') }}">
              {{ csrf_field() }}
              <div class="form-group">
                <label for="mojang_name">Minecraft 正版用户名</label>
                <input type="text" id="mojang_name" name="mojang_name"
                  class="form-control" placeholder="例：Steve"
                  maxlength="16" required
                  {% if not hasPlayer %}disabled{% endif %}>
                <small class="form-text text-muted">区分大小写，请确认与启动器中显示的一致</small>
              </div>
              <button type="submit" class="btn btn-primary btn-block"
                {% if not hasPlayer %}disabled{% endif %}>
                <i class="fas fa-check mr-1"></i>提交并等待验证
              </button>
            </form>
          </div>
          <div class="card-footer bg-transparent">
            <div class="row text-center text-muted small">
              <div class="col-4">
                <i class="fas fa-keyboard d-block mb-1" style="font-size:1.4em;"></i>
                ① 填写用户名
              </div>
              <div class="col-4">
                <i class="fas fa-server d-block mb-1" style="font-size:1.4em;"></i>
                ② 进入服务器
              </div>
              <div class="col-4">
                <i class="fas fa-check-circle d-block mb-1" style="font-size:1.4em;"></i>
                ③ 自动完成
              </div>
            </div>
          </div>
        </div>

      {% endif %}

    </div>
  </div>
</div>
{% endblock %}
